# =============================================================================
# sian-process-intelligence — Variáveis de ambiente (exemplo)
# Copie para .env e preencha conforme seu ambiente. NÃO commite .env.
# =============================================================================

# --- BigQuery (laboratório local: run_local_lab.sh) ---
# Padrão SIAN já embutido no código (dois projetos: suprimentos + financeiro).
# Só defina abaixo se quiser sobrescrever (ex.: outro ambiente).
#
# Tabela      | Project ID                 | Dataset | Uso no lab
# ------------|----------------------------|---------|------------
# SIAN_SE2    | gcp-sian-proj-suprimentos  | silver  | SE2 (títulos)
# SE5         | gcp-sian-proj-suprimentos  | raw     | SE5
# FK7         | gcp-sian-proj-financeiro   | silver  | FK7
# FK2         | gcp-sian-proj-financeiro   | silver  | FK2
#
# BQ_PROJECT_ID=              # fallback único (opcional)
# BQ_DATASET_RAW=             # fallback único (opcional)
# BQ_PROJECT_SE2=             # sobrescreve default SIAN
# BQ_DATASET_SE2=
# BQ_TABLE_SE2=SIAN_SE2
# BQ_PROJECT_FK7= / BQ_DATASET_FK7= / BQ_TABLE_FK7=FK7
# BQ_PROJECT_FK2= / BQ_DATASET_FK2= / BQ_TABLE_FK2=FK2
# BQ_PROJECT_SE5= / BQ_DATASET_SE5= / BQ_TABLE_SE5=SE5
BQ_DATASET_ANALYTICS=

# --- dbt ---
# Perfil dbt (opcional; pode ser bigquery)
DBT_PROFILE=bigquery
# Threads para run
DBT_THREADS=4

# --- Credenciais GCP (obrigatório para acessar o BigQuery) ---
# Opção A: use ADC (gcloud auth application-default login)
# Opção B: defina o caminho para o JSON da service account:
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/sua-service-account.json

# --- Python / Process Mining ---
# Diretório de saída para event logs exportados (opcional)
PROCESS_OUTPUT_DIR=./output
# Formato padrão de export (xes, csv, parquet)
EVENT_LOG_FORMAT=parquet

# --- IA / LLM (futuro) ---
# Endpoint ou API key para modelo (quando integrar)
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=

# --- Laboratório local (Parquet + DuckDB) ---
# LOCAL_LAB_DATA_DIR=./data
# LOCAL_LAB_DB_DIR=./local
# LOCAL_LAB_EXTRACT_LIMIT=0   # 0 = sem limite (tudo); >0 = LIMIT n
# LOCAL_LAB_DATE_FILTER=

# --- Opcional: Cortex / Argos (quando integrar) ---
# CORTEX_URL=
# ARGOS_URL=
